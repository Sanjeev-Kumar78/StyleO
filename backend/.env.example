# connection string for your MongoDB instance
DATABASE_URL="mongodb://localhost:27017/<your_db_name>?maxPoolSize=500&minPoolSize=20&connectTimeoutMS=10000&socketTimeoutMS=30000"

# secret used to sign tokens
SECRET_KEY="<your_secret_key>"

# algorithm for JWTs
ALGORITHM="HS256"

# token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OAuth client id from Google
GOOGLE_CLIENT_ID="<your_google_client_id>.apps.googleusercontent.com"

# redis settings
REDIS_PASSWORD="<your_redis_password>"
# redis db url: 6379/0 -> 0 to 15 dbs available
REDIS_DB_URL="redis://:${REDIS_PASSWORD}@localhost:6379/0"

# set to false for local dev (HTTP), true for production (HTTPS)
COOKIE_SECURE=false